(module example/ledger_test_suite
  (imports
    (airj airj/test TestOutcome
                          fail
                          assert-contract-message
                          assert-int-eq
                          assert-string-eq)
    (java java.lang.IllegalStateException)
    (airj example/ledger balance-label
                          deposit
                          open-account
                          total-balance
                          transfer
                          withdraw))
  (export suite)

  (fn opens-at-zero
    (params)
    (returns TestOutcome)
    (effects ())
    (requires true)
    (ensures true)
    (call (local assert-int-eq)
          "opens account at zero"
          (record-get (call (local open-account) "alice") balance)
          0))

  (fn deposits-positive-amount
    (params)
    (returns TestOutcome)
    (effects ())
    (requires true)
    (ensures true)
    (call (local assert-int-eq)
          "deposit increases balance"
          (record-get
            (call (local deposit)
                  (call (local open-account) "alice")
                  8)
            balance)
          8))

  (fn withdraws-within-balance
    (params)
    (returns TestOutcome)
    (effects ())
    (requires true)
    (ensures true)
    (call (local assert-int-eq)
          "withdraw decreases balance"
          (record-get
            (call (local withdraw)
                  (call (local deposit)
                        (call (local open-account) "alice")
                        9)
                  4)
            balance)
          5))

  (fn transfer-preserves-total
    (params)
    (returns TestOutcome)
    (effects ())
    (requires true)
    (ensures true)
    (call (local assert-int-eq)
          "transfer preserves total"
          (let ((result (call (local transfer)
                              (call (local deposit)
                                    (call (local open-account) "alice")
                                    10)
                              (call (local deposit)
                                    (call (local open-account) "bob")
                                    3)
                              4)))
            (call (local total-balance)
                  (record-get (local result) from)
                  (record-get (local result) to)))
          13))

  (fn transfer-updates-both-sides
    (params)
    (returns TestOutcome)
    (effects ())
    (requires true)
    (ensures true)
    (call (local assert-string-eq)
          "transfer updates both accounts"
          (let ((result (call (local transfer)
                              (call (local deposit)
                                    (call (local open-account) "alice")
                                    10)
                              (call (local deposit)
                                    (call (local open-account) "bob")
                                    1)
                              3)))
            (string-concat
              (call (local balance-label) (record-get (local result) from))
              (string-concat
                "|"
                (call (local balance-label) (record-get (local result) to)))))
          "alice:7|bob:4"))

  (fn labels-balance
    (params)
    (returns TestOutcome)
    (effects ())
    (requires true)
    (ensures true)
    (call (local assert-string-eq)
          "labels balance"
          (call (local balance-label)
                (call (local deposit)
                      (call (local open-account) "alice")
                      6))
          "alice:6"))

  (fn rejects-empty-account-id
    (params)
    (returns TestOutcome)
    (effects (Foreign.Throw))
    (requires true)
    (ensures true)
    (try
      (seq
        (call (local open-account) "")
        (call (local fail)
              "rejects empty account id"
              "Expected contract failure."
              "open-account accepted an empty id."))
      (catch (Java java.lang.IllegalStateException) ex
        (call (local assert-contract-message)
              "rejects empty account id"
              (java/call (local ex) getMessage (signature () String))
              "Precondition"
              "open-account"))))

  (fn rejects-overdraft
    (params)
    (returns TestOutcome)
    (effects (Foreign.Throw))
    (requires true)
    (ensures true)
    (try
      (seq
        (call (local withdraw)
              (call (local deposit)
                    (call (local open-account) "alice")
                    3)
              4)
        (call (local fail)
              "rejects overdraft"
              "Expected contract failure."
              "withdraw accepted an overdraft."))
      (catch (Java java.lang.IllegalStateException) ex
        (call (local assert-contract-message)
              "rejects overdraft"
              (java/call (local ex) getMessage (signature () String))
              "Precondition"
              "withdraw"))))

  (fn suite
    (params)
    (returns (Seq TestOutcome))
    (effects (Foreign.Throw))
    (requires true)
    (ensures true)
    (seq-append
      (seq-append
        (seq-append
          (seq-append
            (seq-append
              (seq-append
                (seq-append
                  (seq-append
                    (seq-empty TestOutcome)
                    (call (local opens-at-zero)))
                  (call (local deposits-positive-amount)))
                (call (local withdraws-within-balance)))
              (call (local transfer-preserves-total)))
            (call (local transfer-updates-both-sides)))
          (call (local labels-balance)))
        (call (local rejects-empty-account-id)))
      (call (local rejects-overdraft)))))
