(module example/wiki_test_suite
  (imports
    (airj airj/core Diagnostic Result Option)
    (airj airj/test TestOutcome
                          fail
                          assert-bool-eq
                          assert-diagnostic-detail
                          assert-int-eq
                          assert-none-string
                          assert-some-string
                          assert-string-eq)
    (airj example/wiki Wiki
                        empty-wiki
                        page-exists?
                        create-page
                        update-page
                        delete-page
                        view-page
                        list-titles
                        search-pages
                        history-bodies
                        invoke-link
                        create-offer
                        rendered-contains-link?
                        rendered-indicates-missing-link?))
  (export suite)

  (fn titles-joined
    (params (titles (Seq String)))
    (returns String)
    (effects ())
    (requires true)
    (ensures true)
    (loop ((remaining (local titles))
           (result ""))
      (if (seq-empty? (local remaining))
        (local result)
        (if (string-empty? (local result))
          (recur
            (seq-rest (local remaining))
            (seq-first (local remaining)))
          (recur
            (seq-rest (local remaining))
            (string-concat
              (local result)
              (string-concat "|" (seq-first (local remaining)))))))))

  (fn wiki-from-home-and-install
    (params)
    (returns Wiki)
    (effects ())
    (requires true)
    (ensures true)
    (match (call (local create-page)
                 (match (call (local create-page)
                              (call (local empty-wiki))
                              "Home"
                              "See [[Install Guide]]")
                   (case (Ok wiki)
                     (local wiki))
                   (case (Err diagnostic)
                     (call (local empty-wiki))))
                 "Install Guide"
                 "Setup steps")
      (case (Ok wiki)
        (local wiki))
      (case (Err diagnostic)
        (call (local empty-wiki)))))

  (fn creates-a-new-page
    (params)
    (returns TestOutcome)
    (effects (Foreign.Throw))
    (requires true)
    (ensures true)
    (match (call (local create-page)
                 (call (local empty-wiki))
                 "Java Basics"
                 "Java is a class-based language.")
      (case (Ok wiki)
        (match (call (local view-page) (local wiki) "Java Basics")
          (case (Ok page-view)
            (call (local assert-string-eq)
                  "creates a new page"
                  (record-get (local page-view) body)
                  "Java is a class-based language."))
          (case (Err diagnostic)
            (call (local fail)
                  "creates a new page"
                  "Expected created page."
                  (record-get (local diagnostic) detail)))))
      (case (Err diagnostic)
        (call (local fail)
              "creates a new page"
              "Page creation failed."
              (record-get (local diagnostic) detail)))))

  (fn rejects-duplicate-title
    (params)
    (returns TestOutcome)
    (effects ())
    (requires true)
    (ensures true)
    (match (call (local create-page)
                 (match (call (local create-page)
                              (call (local empty-wiki))
                              "Java Basics"
                              "Initial content")
                   (case (Ok wiki)
                     (local wiki))
                   (case (Err diagnostic)
                     (call (local empty-wiki))))
                 "Java Basics"
                 "Different content")
      (case (Ok wiki)
        (call (local fail)
              "rejects duplicate title"
              "Expected duplicate rejection."
              "create-page succeeded."))
      (case (Err diagnostic)
        (call (local assert-diagnostic-detail)
              "rejects duplicate title"
              (local diagnostic)
              "page.title.duplicate"))))

  (fn views-existing-page
    (params)
    (returns TestOutcome)
    (effects (Foreign.Throw))
    (requires true)
    (ensures true)
    (match (call (local view-page)
                 (match (call (local create-page)
                              (call (local empty-wiki))
                              "Spring Boot"
                              "A Java framework")
                   (case (Ok wiki)
                     (local wiki))
                   (case (Err diagnostic)
                     (call (local empty-wiki))))
                 "Spring Boot")
      (case (Ok page-view)
        (call (local assert-string-eq)
              "views existing page"
              (record-get (local page-view) title)
              "Spring Boot"))
      (case (Err diagnostic)
        (call (local fail)
              "views existing page"
              "Expected page view."
              (record-get (local diagnostic) detail)))))

  (fn returns-not-found-for-missing-page
    (params)
    (returns TestOutcome)
    (effects (Foreign.Throw))
    (requires true)
    (ensures true)
    (match (call (local view-page) (call (local empty-wiki)) "Missing Page")
      (case (Ok page-view)
        (call (local fail)
              "returns not found for missing page"
              "Expected page.not_found."
              (record-get (local page-view) title)))
      (case (Err diagnostic)
        (call (local assert-diagnostic-detail)
              "returns not found for missing page"
              (local diagnostic)
              "page.not_found"))))

  (fn edits-an-existing-page
    (params)
    (returns TestOutcome)
    (effects (Foreign.Throw))
    (requires true)
    (ensures true)
    (match (call (local update-page)
                 (match (call (local create-page)
                              (call (local empty-wiki))
                              "Build Tool"
                              "Use Ant")
                   (case (Ok wiki)
                     (local wiki))
                   (case (Err diagnostic)
                     (call (local empty-wiki))))
                 "Build Tool"
                 "Use Maven or Gradle.")
      (case (Ok wiki)
        (match (call (local view-page) (local wiki) "Build Tool")
          (case (Ok page-view)
            (call (local assert-string-eq)
                  "edits an existing page"
                  (record-get (local page-view) body)
                  "Use Maven or Gradle."))
          (case (Err diagnostic)
            (call (local fail)
                  "edits an existing page"
                  "Expected updated page."
                  (record-get (local diagnostic) detail)))))
      (case (Err diagnostic)
        (call (local fail)
              "edits an existing page"
              "Update failed."
              (record-get (local diagnostic) detail)))))

  (fn deletes-a-page
    (params)
    (returns TestOutcome)
    (effects ())
    (requires true)
    (ensures true)
    (match (call (local delete-page)
                 (match (call (local create-page)
                              (call (local empty-wiki))
                              "Temporary"
                              "to be removed")
                   (case (Ok wiki)
                     (local wiki))
                   (case (Err diagnostic)
                     (call (local empty-wiki))))
                 "Temporary")
      (case (Ok wiki)
        (call (local assert-bool-eq)
              "deletes a page"
              (call (local page-exists?) (local wiki) "Temporary")
              false))
      (case (Err diagnostic)
        (call (local fail)
              "deletes a page"
              "Delete failed."
              (record-get (local diagnostic) detail)))))

