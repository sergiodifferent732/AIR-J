                 (call (local wiki-from-home-and-install))
                 "Home"
                 "Install Guide")
      (case (Ok page-view)
        (call (local assert-string-eq)
              "follows a rendered wiki link"
              (record-get (local page-view) body)
              "Setup steps"))
      (case (Err diagnostic)
        (call (local fail)
              "follows a rendered wiki link"
              "Expected linked page."
              (record-get (local diagnostic) detail)))))

