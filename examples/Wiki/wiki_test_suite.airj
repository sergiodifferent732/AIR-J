                              (call (local empty-wiki))
                              "Home"
                              "See [[Missing Guide]]")
                   (case (Ok wiki)
                     (local wiki))
                   (case (Err diagnostic)
                     (call (local empty-wiki))))
                 "Home")
      (case (Ok page-view)
        (call (local assert-bool-eq)
              "marks a link to a missing page"
              (call (local rendered-indicates-missing-link?)
                    (record-get (local page-view) rendered)
                    "Missing Guide")
              true))
      (case (Err diagnostic)
        (call (local fail)
              "marks a link to a missing page"
              "Expected rendered page."
              (record-get (local diagnostic) detail)))))

  (fn offers-page-creation-for-missing-link
    (params)
    (returns TestOutcome)
    (effects ())
    (requires true)
    (ensures true)
    (call (local assert-some-string)
          "offers page creation for missing link"
          (call (local create-offer)
                (match (call (local create-page)
                             (call (local empty-wiki))
                             "Home"
                             "See [[Missing Guide]]")
                  (case (Ok wiki)
                    (local wiki))
                  (case (Err diagnostic)
                    (call (local empty-wiki))))
                "Missing Guide")
          "Missing Guide"))

  (fn supports-a-page-linking-to-itself
    (params)
    (returns TestOutcome)
    (effects (Foreign.Throw))
    (requires true)
    (ensures true)
    (match (call (local view-page)
                 (match (call (local create-page)
                              (call (local empty-wiki))
                              "Home"
                              "Back to [[Home]]")
                   (case (Ok wiki)
                     (local wiki))
                   (case (Err diagnostic)
                     (call (local empty-wiki))))
                 "Home")
      (case (Ok page-view)
        (call (local assert-bool-eq)
              "supports a page linking to itself"
              (call (local rendered-contains-link?)
                    (record-get (local page-view) rendered)
                    "Home")
              true))
      (case (Err diagnostic)
        (call (local fail)
              "supports a page linking to itself"
              "Expected rendered page."
              (record-get (local diagnostic) detail)))))

  (fn renders-headings-and-paragraphs
    (params)
    (returns TestOutcome)
    (effects (Foreign.Throw))
    (requires true)
    (ensures true)
    (match (call (local view-page)
                 (match (call (local create-page)
                              (call (local empty-wiki))
                              "Home"
                              "# Welcome\n\nThis is the home page.")
                   (case (Ok wiki)
                     (local wiki))
                   (case (Err diagnostic)
                     (call (local empty-wiki))))
                 "Home")
      (case (Ok page-view)
        (call (local assert-string-eq)
              "renders headings and paragraphs"
              (record-get (local page-view) rendered)
              "<h1>Welcome</h1><p>This is the home page.</p>"))
      (case (Err diagnostic)
        (call (local fail)
              "renders headings and paragraphs"
              "Expected rendered page."
              (record-get (local diagnostic) detail)))))

  (fn renders-emphasis-and-strong-text
    (params)
    (returns TestOutcome)
    (effects (Foreign.Throw))
    (requires true)
    (ensures true)
    (match (call (local view-page)
                 (match (call (local create-page)
                              (call (local empty-wiki))
                              "Formatting"
                              "Use *italics* and **bold** for emphasis.")
                   (case (Ok wiki)
                     (local wiki))
                   (case (Err diagnostic)
                     (call (local empty-wiki))))
                 "Formatting")
      (case (Ok page-view)
        (call (local assert-string-eq)
              "renders emphasis and strong text"
              (record-get (local page-view) rendered)
              "<p>Use <em>italics</em> and <strong>bold</strong> for emphasis.</p>"))
      (case (Err diagnostic)
        (call (local fail)
              "renders emphasis and strong text"
              "Expected rendered page."
              (record-get (local diagnostic) detail)))))

  (fn renders-unordered-lists
    (params)
    (returns TestOutcome)
    (effects (Foreign.Throw))
    (requires true)
    (ensures true)
    (match (call (local view-page)
                 (match (call (local create-page)
                              (call (local empty-wiki))
                              "Checklist"
                              "- Install Java\n- Run Maven\n- Start the server")
                   (case (Ok wiki)
                     (local wiki))
                   (case (Err diagnostic)
                     (call (local empty-wiki))))
                 "Checklist")
      (case (Ok page-view)
        (call (local assert-string-eq)
              "renders unordered lists"
              (record-get (local page-view) rendered)
              "<ul><li>Install Java</li><li>Run Maven</li><li>Start the server</li></ul>"))
      (case (Err diagnostic)
        (call (local fail)
              "renders unordered lists"
              "Expected rendered page."
              (record-get (local diagnostic) detail)))))

  (fn renders-wiki-links-inside-markdown
    (params)
    (returns TestOutcome)
    (effects (Foreign.Throw))
    (requires true)
    (ensures true)
    (match (call (local view-page)
                 (match (call (local create-page)
                              (match (call (local create-page)
                                           (call (local empty-wiki))
                                           "Home"
                                           "# Welcome\n\nStart with [[Install Guide]].")
                                (case (Ok wiki)
                                  (local wiki))
                                (case (Err diagnostic)
                                  (call (local empty-wiki))))
                              "Install Guide"
                              "Setup steps")
                   (case (Ok wiki)
                     (local wiki))
                   (case (Err diagnostic)
                     (call (local empty-wiki))))
                 "Home")
      (case (Ok page-view)
        (call (local assert-string-eq)
              "renders wiki links inside markdown"
              (record-get (local page-view) rendered)
              "<h1>Welcome</h1><p>Start with <a href=\"Install Guide\">Install Guide</a>.</p>"))
      (case (Err diagnostic)
        (call (local fail)
              "renders wiki links inside markdown"
              "Expected rendered page."
              (record-get (local diagnostic) detail)))))

  (fn leaves-unclosed-wiki-link-as-literal-text
    (params)
    (returns TestOutcome)
    (effects (Foreign.Throw))
    (requires true)
    (ensures true)
    (match (call (local view-page)
                 (match (call (local create-page)
                              (call (local empty-wiki))
                              "Home"
                              "See [[Install Guide")
                   (case (Ok wiki)
                     (local wiki))
                   (case (Err diagnostic)
                     (call (local empty-wiki))))
                 "Home")
      (case (Ok page-view)
        (call (local assert-string-eq)
              "leaves unclosed wiki link as literal text"
              (record-get (local page-view) rendered)
              "<p>See [[Install Guide</p>"))
      (case (Err diagnostic)
        (call (local fail)
              "leaves unclosed wiki link as literal text"
              "Expected rendered page."
              (record-get (local diagnostic) detail)))))

  (fn suite
    (params)
    (returns (Seq TestOutcome))
    (effects (Foreign.Throw))
    (requires true)
    (ensures true)
    (seq-concat
      (seq-concat
        (seq-concat
          (seq-concat
            (seq-concat
              (seq-concat
                (seq-concat
                  (seq-concat
                    (seq-concat
                      (call (local singleton-test) (call (local creates-a-new-page)))
                      (call (local singleton-test) (call (local rejects-duplicate-title))))
                    (call (local singleton-test) (call (local views-existing-page))))
                  (call (local singleton-test) (call (local returns-not-found-for-missing-page))))
                (call (local singleton-test) (call (local edits-an-existing-page))))
              (call (local singleton-test) (call (local deletes-a-page))))
            (call (local singleton-test) (call (local rejects-blank-title))))
          (call (local singleton-test) (call (local rejects-blank-body))))
        (seq-concat
          (seq-concat
            (seq-concat
              (seq-concat
                (seq-concat
                  (call (local singleton-test) (call (local trims-new-page-title)))
                  (call (local singleton-test) (call (local lists-page-titles-alphabetically))))
                (call (local singleton-test) (call (local searches-pages-by-title-and-body))))
              (call (local singleton-test) (call (local rejects-blank-search-query))))
            (call (local singleton-test) (call (local keeps-revision-history-after-edits))))
          (call (local singleton-test) (call (local renders-wiki-link-to-existing-page)))))
      (seq-concat
        (seq-concat
          (seq-concat
            (seq-concat
              (seq-concat
                (call (local singleton-test) (call (local follows-a-rendered-wiki-link)))
                (call (local singleton-test) (call (local marks-a-link-to-a-missing-page))))
              (call (local singleton-test) (call (local offers-page-creation-for-missing-link))))
            (call (local singleton-test) (call (local supports-a-page-linking-to-itself))))
          (call (local singleton-test) (call (local renders-headings-and-paragraphs))))
        (seq-concat
          (seq-concat
            (call (local singleton-test) (call (local renders-emphasis-and-strong-text)))
            (call (local singleton-test) (call (local renders-unordered-lists))))
          (seq-concat
            (call (local singleton-test)
                  (call (local renders-wiki-links-inside-markdown)))
            (call (local singleton-test)
                  (call (local leaves-unclosed-wiki-link-as-literal-text))))))))

  (fn singleton-test
    (params (test TestOutcome))
    (returns (Seq TestOutcome))
    (effects ())
    (requires true)
    (ensures true)
    (seq-append
      (seq-empty TestOutcome)
      (local test))))
)
