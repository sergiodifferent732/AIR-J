  (fn trims-new-page-title
    (params)
    (returns TestOutcome)
    (effects ())
    (requires true)
    (ensures true)
    (match (call (local create-page)
                 (call (local empty-wiki))
                 "  Java Basics  "
                 "Core concepts")
      (case (Ok wiki)
        (call (local assert-bool-eq)
              "trims new page title"
              (call (local page-exists?) (local wiki) "Java Basics")
              true))
      (case (Err diagnostic)
        (call (local fail)
              "trims new page title"
              "Expected trimmed title to create."
              (record-get (local diagnostic) detail)))))

  (fn lists-page-titles-alphabetically
    (params)
    (returns TestOutcome)
    (effects (Foreign.Throw))
    (requires true)
    (ensures true)
    (let ((wiki-three
            (match (call (local create-page)
                         (match (call (local create-page)
                                      (match (call (local create-page)
                                                   (call (local empty-wiki))
                                                   "Zeta"
                                                   "last")
                                        (case (Ok wiki)
                                          (local wiki))
                                        (case (Err diagnostic)
                                          (call (local empty-wiki))))
                                      "Alpha"
                                      "first")
                           (case (Ok wiki)
                             (local wiki))
                           (case (Err diagnostic)
                             (call (local empty-wiki))))
                         "Gamma"
                         "middle")
              (case (Ok wiki)
                (local wiki))
              (case (Err diagnostic)
                (call (local empty-wiki))))))
      (call (local assert-string-eq)
            "lists page titles alphabetically"
            (call (local titles-joined) (call (local list-titles) (local wiki-three)))
            "Alpha|Gamma|Zeta")))

  (fn searches-pages-by-title-and-body
    (params)
    (returns TestOutcome)
    (effects (Foreign.Throw))
    (requires true)
    (ensures true)
    (let ((wiki-three
            (match (call (local create-page)
                         (match (call (local create-page)
                                      (match (call (local create-page)
                                                   (call (local empty-wiki))
                                                   "Dependency Injection"
                                                   "Spring supports Java dependency injection")
                                        (case (Ok wiki)
                                          (local wiki))
                                        (case (Err diagnostic)
                                          (call (local empty-wiki))))
                                      "Testing"
                                      "Use JUnit for Java")
                           (case (Ok wiki)
                             (local wiki))
                           (case (Err diagnostic)
                             (call (local empty-wiki))))
                         "Containers"
                         "Docker basics")
              (case (Ok wiki)
                (local wiki))
              (case (Err diagnostic)
                (call (local empty-wiki))))))
      (match (call (local search-pages) (local wiki-three) "Java")
        (case (Ok titles)
          (call (local assert-string-eq)
                "searches pages by title and body"
                (call (local titles-joined) (local titles))
                "Dependency Injection|Testing"))
        (case (Err diagnostic)
          (call (local fail)
                "searches pages by title and body"
                "Search failed."
                (record-get (local diagnostic) detail))))))

  (fn rejects-blank-search-query
    (params)
    (returns TestOutcome)
    (effects (Foreign.Throw))
    (requires true)
    (ensures true)
    (match (call (local search-pages) (call (local empty-wiki)) "")
      (case (Ok titles)
        (call (local fail)
              "rejects blank search query"
              "Expected blank search rejection."
              (call (local titles-joined) (local titles))))
      (case (Err diagnostic)
        (call (local assert-diagnostic-detail)
              "rejects blank search query"
              (local diagnostic)
              "search.query.blank"))))

  (fn keeps-revision-history-after-edits
    (params)
    (returns TestOutcome)
    (effects ())
    (requires true)
    (ensures true)
    (match (call (local history-bodies)
                 (match (call (local update-page)
                              (match (call (local update-page)
                                           (match (call (local create-page)
                                                        (call (local empty-wiki))
                                                        "Roadmap"
                                                        "v1")
                                             (case (Ok wiki)
                                               (local wiki))
                                             (case (Err diagnostic)
                                               (call (local empty-wiki))))
                                           "Roadmap"
                                           "v2")
                                (case (Ok wiki)
                                  (local wiki))
                                (case (Err diagnostic)
                                  (call (local empty-wiki))))
                              "Roadmap"
                              "v3")
                   (case (Ok wiki)
                     (local wiki))
                   (case (Err diagnostic)
                     (call (local empty-wiki))))
                 "Roadmap")
      (case (Ok bodies)
        (call (local assert-string-eq)
              "keeps revision history after edits"
              (call (local titles-joined) (local bodies))
              "v1|v2|v3"))
      (case (Err diagnostic)
        (call (local fail)
              "keeps revision history after edits"
              "Expected revision history."
              (record-get (local diagnostic) detail)))))

  (fn renders-wiki-link-to-existing-page
    (params)
    (returns TestOutcome)
    (effects (Foreign.Throw))
    (requires true)
    (ensures true)
    (match (call (local view-page)
                 (call (local wiki-from-home-and-install))
                 "Home")
      (case (Ok page-view)
        (call (local assert-bool-eq)
              "renders wiki link to existing page"
              (call (local rendered-contains-link?)
                    (record-get (local page-view) rendered)
                    "Install Guide")
              true))
      (case (Err diagnostic)
        (call (local fail)
              "renders wiki link to existing page"
              "Expected rendered page."
              (record-get (local diagnostic) detail)))))

  (fn follows-a-rendered-wiki-link
    (params)
    (returns TestOutcome)
    (effects (Foreign.Throw))
    (requires true)
    (ensures true)
